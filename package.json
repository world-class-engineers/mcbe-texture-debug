{
  "name": "texture-debug",
  "version": "1.1.0",
  "productName": "Texture Debug",
  "description": "A Minecraft Bedrock add-on for debugging textures.",
  "private": true,
  "license": "MIT",
  "scripts": {
    "watch": "npx concurrently -n 'build,test' --kill-others-on-fail \"npm run watch:deploy\" \"npm run watch:test\"",
    "watch:deploy": "just-scripts local-deploy --watch",
    "watch:test": "vitest --watch --clearScreen=false",
    "lint": "just-scripts lint",
    "build": "just-scripts build",
    "build:production": "just-scripts build --production",
    "clean": "just-scripts clean",
    "local-deploy": "just-scripts local-deploy",
    "mcaddon": "just-scripts mcaddon",
    "mcaddon:production": "just-scripts mcaddon --production",
    "enablemcloopback": "CheckNetIsolation.exe LoopbackExempt -a -p=S-1-15-2-1958404141-86561845-1752920682-3514627264-368642714-62675701-733520436",
    "enablemcpreviewloopback": "CheckNetIsolation.exe LoopbackExempt -a -p=S-1-15-2-424268864-5579737-879501358-346833251-474568803-887069379-4040235476",
    "test": "vitest run"
  },
  "dependencies": {
    "@minecraft/math": "2.4.0",
    "@minecraft/server": "2.8.0",
    "@minecraft/server-ui": "2.1.0",
    "@minecraft/vanilla-data": "1.26.30",
    "change-case": "^5.4.4",
    "mcbe-item-ids": "^0.1.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@minecraft/core-build-tasks": "5.5.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "cheerio": "^1.2.0",
    "concurrently": "^10.0.3",
    "eslint-plugin-minecraft-linting": "2.0.10",
    "jsdom": "^29.1.1",
    "just-scripts": "2.6.0",
    "kinda-type": "^1.0.4",
    "linkedom": "^0.18.12",
    "polyfill-pseudoclass-has": "^1.1.0",
    "prettier": "3.8.3",
    "semver": "^7.8.2",
    "source-map": "0.7.4",
    "ts-node": "10.9.1",
    "typescript": "5.5.4",
    "varlock": "^1.5.0",
    "vitest": "4.1.8"
  }
}
