  "page_label": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "anchor_from": "center_middle",
    "anchor_to": "center_middle",
    "size": ["default", 7],
    "offset": [0, -1],
    "layer": 10,
    "controls": [
      {
        "page_number_label": {
          "type": "label",
          "text": "#page_number",
          "color": [1, 1, 1, 1],
          "layer": 10,
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "(('§z') + (('%.107s' * #title_text) - ('%.105s' * #title_text)))",
              "target_property_name": "#page_number"
            }
          ]
        }
      },
      {
        "divider_label": {
          "type": "label",
          "text": "/",
          "color": [1, 1, 1, 1],
          "layer": 10
        }
      },
      {
        "total_pages_label": {
          "type": "label",
          "text": "#total_pages",
          "color": [1, 1, 1, 1],
          "layer": 10,
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "(('§z') + (('%.122s' * #title_text) - ('%.120s' * #title_text)))",
              "target_property_name": "#total_pages"
            }
          ]
        }
      }
    ]
  },

  "collection_browser_grid_wrapper": {
    "type": "panel",
    "size": [306, 126],
    "offset": [3, 3],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "clips_children": true,
    "controls": [{ "grid@collection_browser_grid": { "size": [315, 134] } }]
  },

  "collection_browser_grid": {
    "type": "grid",
    "size": [306, 144],
    "min_size": [306, 144],
    "max_size": [306, 144],
    "offset": [0, -18],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "grid_item_template": "collect_everything.inventory_slot_button",
    "collection_name": "form_buttons",
    "$item_collection_name": "form_buttons",
    "grid_rescaling_type": "none",
    "grid_dimensions": [17, 8]
  },

  "gap": { "type": "panel" }
}
