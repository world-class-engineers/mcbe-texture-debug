{
  "namespace": "texture_debug",

  "texture_debug_screen": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [{ "texture_debug_modal@texture_debug.texture_debug_modal": {} }],
    "bindings": [
      { "binding_name": "#title_text" },
      {
        "binding_type": "view",
        // only show when special data header is sent on the title
        "source_property_name": "(not ((#title_text - $custom_form_data_prefix) = #title_text))",
        "target_property_name": "#visible"
      }
    ]
  },

  "texture_debug_modal": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": [325, 177],
    "layer": 15,
    "controls": [{ "top_panel@texture_debug.top_panel": {} }, { "main_panel@texture_debug.main_panel": {} }]
  },

  "top_panel": {
    "type": "panel",
    "size": [325, 20],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [{ "top_right_panel@texture_debug.top_right_panel": {} }]
  },

  "button_highlight_dark_background_white_foreground": {
    "type": "custom",
    "renderer": "gradient_renderer",
    "color1": [0.58, 0.58, 0.58, 1],
    "color2": [0.58, 0.58, 0.58, 1],
    "size": ["100%", "100%"]
  },

  "toolbar_button@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "$icon_control|default": "settings_icon",
    "$tooltip_text|default": "",
    "size": [15, 15],
    "offset": [0, -5],
    "layer": 2,
    "default_control": "default_button",
    "hover_control": "hover_button",
    "pressed_control": "pressed_button",
    "anchor_from": "center",
    "anchor_to": "center",
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ],
    "controls": [
      {
        "default_button": {
          "type": "panel",
          "controls": [{ "icon@texture_debug.$icon_control": {} }]
        }
      },
      {
        "hover_button": {
          "type": "panel",
          "controls": [
            { "highlight@texture_debug.button_highlight_dark_background_white_foreground": {} },
            { "icon@texture_debug.$icon_control": {} }
          ]
        }
      },
      {
        "pressed_button": {
          "type": "panel",
          "controls": [
            { "highlight@texture_debug.button_highlight_dark_background_white_foreground": {} },
            { "icon@texture_debug.$icon_control": {} }
          ]
        }
      }
    ]
  },

  "settings_icon": {
    "type": "image",
    "texture": "textures/ui/settings",
    "size": [8, 6]
  },

  "top_right_panel": {
    "type": "image",
    "texture": "textures/ui/TabTopBackRightMostDark",
    "size": [45, 24],
    "offset": [-2, 0],
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "layer": 0,
    "controls": [
      {
        "top_right_buttons": {
          "type": "stack_panel",
          "anchor_from": "top_right",
          "anchor_to": "top_right",
          "offset": [-5, 4],
          "orientation": "horizontal",
          "collection_name": "form_buttons",
          "controls": [
            // IMPORTANT: these hardcoded indexes need
            // to stay in sync with button insertion order
            // from script side
            {
              "settings_button@texture_debug.toolbar_button": {
                "$icon_control": "settings_icon",
                "$tooltip_text": "Settings",
                "collection_index": 2
              }
            },
            {
              "close_button@common.light_close_button": { "size": [15, 15] }
            }
          ]
        }
      }
    ]
  },

  "modal_title": {
    "type": "label",
    "text": "#display_text",
    "color": "$title_text_color",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "bindings": [
      {
        "binding_type": "view",
        // remove data header from title string
        "source_property_name": "(#title_text - ('%.95s' * #title_text))",
        "target_property_name": "#display_text"
      }
    ]
  },

  "main_panel": {
    "type": "image",
    "texture": "textures/ui/dialog_background_opaque",
    "size": ["100%", "100%"],
    "layer": 0,
    "controls": [
      {
        "main_contents": {
          "type": "panel",
          "size": ["100%", "100%"],
          "offset": [6, 9],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "controls": [
            { "modal_title@texture_debug.modal_title": {} },
            { "@gap": { "size": [0, 3] } },
            { "@items_panel": {} }
          ]
        }
      }
    ]
  },

  "items_panel": {
    "type": "image",
    "texture": "textures/ui/dialog_inset_background",
    "offset": [0, 12],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "size": [313, 150],
    "controls": [{ "@items_grid_wrapper": {} }, { "@items_pagination": {} }]
  },

  "items_pagination": {
    "type": "panel",
    "size": [55, 17],
    "offset": [0, -3],
    "anchor_from": "bottom_middle",
    "anchor_to": "bottom_middle",
    "controls": [
      {
        "previous_button@pagination_button": {
          "$texture_path_default": "textures/ui/page_previous",
          "$texture_path_active": "textures/ui/page_previous_active",
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "property_bag": {
            // IMPORTANT: these hardcoded indexes need
            // to stay in sync with button insertion order
            // from script side
            "#collection_index": 0,
            "#collection_name": "form_buttons"
          },
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "((#title_text - '|hasPrevious|:0') = #title_text)",
              "target_property_name": "#visible"
            }
          ]
        }
      },
      { "page_label@page_label": {} },
      {
        "next_button@pagination_button": {
          "$texture_path_default": "textures/ui/page_next",
          "$texture_path_active": "textures/ui/page_next_active",
          "anchor_from": "right_middle",
          "anchor_to": "right_middle",
          "property_bag": {
            // IMPORTANT: these hardcoded indexes need
            // to stay in sync with button insertion order
            // from script side
            "#collection_index": 1,
            "#collection_name": "form_buttons"
          },
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "((#title_text - '|hasNext|:0') = #title_text)",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },

  "pagination_button_image": {
    "type": "image",
    "$texture_path|default": "",
    "texture": "$texture_path",
    "size": [11, 17],
    "layer": 10
  },

  "pagination_button@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "$texture_path_default|default": "",
    "$texture_path_active|default": "",
    "size": [11, 17],
    "layer": 10,
    "default_control": "default",
    "hover_control": "hover",
    "pressed_control": "pressed",
    "controls": [
      { "default@pagination_button_image": { "$texture_path": "$texture_path_default" } },
      { "hover@pagination_button_image": { "$texture_path": "$texture_path_active" } },
      { "pressed@pagination_button_image": { "$texture_path": "$texture_path_active" } }
    ],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ]
  },

  "page_label": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "anchor_from": "center_middle",
    "anchor_to": "center_middle",
    "size": ["default", 7],
    "offset": [0, -1],
    "layer": 10,
    "controls": [
      {
        "page_number_label": {
          "type": "label",
          "text": "#page_number",
          "color": [1, 1, 1, 1],
          "layer": 10,
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "(('§z') + (('%.80s' * #title_text) - ('%.78s' * #title_text)))",
              "target_property_name": "#page_number"
            }
          ]
        }
      },
      {
        "divider_label": {
          "type": "label",
          "text": "/",
          "color": [1, 1, 1, 1],
          "layer": 10
        }
      },
      {
        "total_pages_label": {
          "type": "label",
          "text": "#total_pages",
          "color": [1, 1, 1, 1],
          "layer": 10,
          "bindings": [
            {
              "binding_type": "view",
              "source_property_name": "(('§z') + (('%.95s' * #title_text) - ('%.93s' * #title_text)))",
              "target_property_name": "#total_pages"
            }
          ]
        }
      }
    ]
  },

  "items_grid_wrapper": {
    "type": "panel",
    "size": [306, 126],
    "offset": [3, 3],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "clips_children": true,
    "controls": [{ "grid@items_grid": { "size": [315, 134] } }]
  },

  "items_grid": {
    "type": "grid",
    "size": [306, 144],
    "min_size": [306, 144],
    "max_size": [306, 144],
    "offset": [0, -18],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "grid_item_template": "texture_debug.inventory_slot_button",
    "collection_name": "form_buttons",
    "$item_collection_name": "form_buttons",
    "grid_rescaling_type": "none",
    "grid_dimensions": [17, 8]
  },

  "gap": { "type": "panel" },

  "inventory_slot_button": {
    "type": "panel",
    "size": [18, 18],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        // don't render the first row, and don't render nonexistent buttons
        "source_property_name": "((not (#collection_index < ($hidden_rows * $cells_per_row))) and (not (#form_button_text = '')))",
        "target_property_name": "#visible"
      }
    ],
    "controls": [{ "@inventory_slot_button_internal": {} }]
  },

  "inventory_slot_button_internal@common.button": {
    "$pressed_button_name": "button.form_button_click",
    "size": [18, 18],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ],
    "default_control": "inventory_slot_default_view",
    "hover_control": "inventory_slot_hover_view",
    "pressed_control": "inventory_slot_pressed_view",
    "controls": [
      { "inventory_slot_default_view@inventory_cell": {} },
      { "inventory_slot_hover_view@inventory_cell": { "$hover": true } },
      { "inventory_slot_pressed_view@inventory_cell": { "$pressed": true } }
    ]
  },

  "inventory_cell": {
    "type": "panel",
    "size": [18, 18],
    "$hover|default": false,
    "$pressed|default": false,
    "controls": [
      { "background@inventory_cell_background": {} },
      { "item@inventory_item": {} },
      { "highlight@inventory_cell_highlight": { "visible": "($hover or $pressed)" } },
      { "focus_border@inventory_cell_focus_border": { "visible": "($hover or $pressed)" } }
    ]
  },

  "inventory_item": {
    "type": "panel",
    "size": [18, 18],
    "bindings": [
      {
        "binding_name": "#null",
        "binding_type": "collection",
        "binding_condition": "none",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#null",
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      }
    ],
    "$aux_id": [
      {
        "binding_name": "#form_button_texture",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        // if the first 8 bytes of the #form_button_texture string isn't 'textures', show this (numerical id texture)
        "source_property_name": "(not (('%.8s' * #form_button_texture) = 'textures'))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#form_button_texture - (#form_button_texture % 65536)) / 65536)",
        "target_property_name": "#item_id_aux"
      }
    ],
    "controls": [
      // if texture is a number, it renders via inventory item renderer
      {
        "@beacon.item_renderer": {
          "size": [16, 16],
          "offset": [1, 1],
          "layer": 4,
          "bindings": "$aux_id"
        }
      },
      // if texture is a texture path, it renders as an image
      { "@item_texture": {} },
      { "@inventory_item_details": { "visible": "$hover" } }
    ]
  },

  "inventory_cell_background": {
    "type": "image",
    "texture": "textures/ui/item_background",
    "size": [18, 18],
    "layer": 2
  },

  "inventory_cell_highlight": {
    "type": "image",
    "size": [18, 18],
    "texture": "textures/ui/highlight_slot",
    "layer": 3
  },

  "inventory_cell_focus_border": {
    "type": "image",
    "size": [18, 18],
    "texture": "textures/ui/focus_border_white",
    "layer": 9
  },

  "item_texture": {
    "type": "image",
    "size": [16, 16],
    "layer": 4,
    "bindings": [
      {
        "binding_name": "#form_button_texture",
        "binding_name_override": "#texture",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "(('%.8s' * #texture) = 'textures')",
        "target_property_name": "#visible"
      }
    ]
  },

  "inventory_item_details": {
    "type": "custom",
    "renderer": "hover_text_renderer",
    "allow_clipping": false,
    "layer": 30,
    "bindings": [
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        "source_property_name": "(#form_button_text - ('%.10s' * #form_button_text))",
        "target_property_name": "#hover_text"
      },
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  }
}
