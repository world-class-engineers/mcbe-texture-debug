{
  "namespace": "server_form",

  // for an explanation of the what and why of this file, see the tutorial at
  // https://wiki.bedrock.dev/json-ui/modifying-server-forms

  "long_form": {
    "modifications": [
      {
        "array_name": "bindings",
        "operation": "insert_back",
        "value": [
          { "binding_name": "#title_text" },
          {
            "binding_type": "view",
            // hide vanilla action form when our custom forms are shown
            "source_property_name": "((#title_text - $custom_form_data_prefix) = #title_text)",
            "target_property_name": "#visible"
          }
        ]
      }
    ]
  },

  "main_screen_content": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "texture_debug_form_factory": {
              "type": "screen",
              "close_on_player_hurt": true,
              "factory": {
                "name": "server_form_factory",
                "control_ids": {
                  "long_form": "@texture_debug.texture_debug_screen"
                }
              }
            }
          }
        ]
      }
    ]
  }
}
